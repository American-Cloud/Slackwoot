# SlackWoot Environment Configuration
# ─────────────────────────────────────
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# .env is gitignored — never commit it with real values.

# ── Required ──────────────────────────────────────────────────────────────────
# Encryption key for all sensitive values stored in the database.
# Generate with: openssl rand -hex 32
# NEVER change this after initial setup — it will invalidate all stored credentials.
SECRET_KEY=

# ── Optional — uncomment to override defaults ─────────────────────────────────

# Database URL (default: SQLite)
# For PostgreSQL, uncomment and set:
# DATABASE_URL=postgresql+asyncpg://slackwoot:password@postgres:5432/slackwoot
# DATABASE_URL=sqlite+aiosqlite:///data/slackwoot.db

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# Use DEBUG temporarily when troubleshooting — it logs full payloads
# LOG_LEVEL=INFO

# Port to expose on the host (default: 8000)
# PORT=8000

# PostgreSQL password (only needed if using the postgres service in docker-compose)
# POSTGRES_PASSWORD=changeme
